<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="Bloc CLI" Language="1033" Version="0.1.0" Manufacturer="Bloc" UpgradeCode="9479b183-ecd2-4c49-a1e1-fe2b41eac9f0">
        <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder">
                <Directory Id="INSTALLFOLDER" Name="Bloc" />
            </Directory>
        </Directory>

        <DirectoryRef Id="INSTALLFOLDER">
            <!-- Win64="yes" is required for components inside ProgramFiles64Folder (ICE80) -->
            <Component Id="BlocExecutable" Guid="d866a2be-7c85-48fa-8692-747d84b259f1" Win64="yes">
                <File Id="BlocEXE" Source="bloc.exe" KeyPath="yes" />
            </Component>

            <!-- Add installation directory to system PATH -->
            <!-- Win64="yes" required (ICE80); RegistryValue provides the KeyPath (ICE18) -->
            <Component Id="BlocPathEnv" Guid="e97a31b6-d5c2-40de-b4f1-6cf1b43b67e2" Win64="yes">
                <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]" Action="set" Part="last" System="yes" Permanent="no" />
                <RegistryValue Root="HKLM" Key="Software\Bloc" Name="PathConfigured" Value="1" Type="integer" KeyPath="yes" />
            </Component>
        </DirectoryRef>

        <Feature Id="ProductFeature" Title="Bloc CLI" Level="1">
            <ComponentRef Id="BlocExecutable" />
            <ComponentRef Id="BlocPathEnv" />
        </Feature>
    </Product>
</Wix>
